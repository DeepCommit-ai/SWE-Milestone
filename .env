# EvoClaw host configuration — PUBLIC TEMPLATE (committed, no secrets here).
#
# Copy the keys you need into `.env_private` (gitignored) with YOUR real values.
# `scripts/run_all.py` auto-loads BOTH at launch: `.env` first, then
# `.env_private` (which overrides it). A real shell-exported var wins over both,
# so you can still do a one-off `EVOCLAW_DATA_ROOT=... python scripts/run_all.py`.
#
# Set these ONCE in .env_private and they persist across shells — no re-export.

# REQUIRED: where you downloaded the EvoClaw-data dataset (from HuggingFace).
# Trial configs can then use `data_root: ${EVOCLAW_DATA_ROOT}` (no host path).
EVOCLAW_DATA_ROOT=/path/to/EvoClaw-data

# QUARANTINE ONLY: base dir holding the per-repo offline pip wheelhouses.
# quarantine_configs/<repo>.yaml references ${EVOCLAW_WHEELHOUSE_DIR}/<name>.
# Only needed when running a repo that has a quarantine_configs policy.
EVOCLAW_WHEELHOUSE_DIR=/path/to/wheelhouses

# OPTIONAL: third-party model auth (Route A). See docs/adding-a-model.md.
# UNIFIED_API_KEY=
# UNIFIED_BASE_URL=

# OPTIONAL: Vertex AI project override (default: the ADC quota project).
# EVOCLAW_VERTEX_PROJECT=
